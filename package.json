{
  "name": "ro-pvp-arena",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/server && npm run build -w apps/web",
    "build:deploy": "npm run build -w packages/shared && npm run build -w apps/web",
    "start": "npx ts-node --transpile-only deploy/server.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "@types/express": "^4.17.0"
  },
  "dependencies": {
    "next": "^14.2.0",
    "express": "^4.18.0",
    "colyseus": "^0.15.0",
    "@colyseus/ws-transport": "^0.15.0",
    "@colyseus/monitor": "^0.15.0",
    "dotenv": "^16.4.0"
  }
}
